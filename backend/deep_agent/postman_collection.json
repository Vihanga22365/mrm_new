              "raw": "{\n  \"chapter\": \"Model Governance\",\n  \"chapter_description\": \"Explain governance controls\",\n  \"instructions\": \"Keep concise and formal\",\n  \"structure_content\": \"## Model Governance\",\n  \"usecase_content\": \"Usecase details here\"\n}",
