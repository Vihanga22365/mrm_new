            "body": {
              "mode": "raw",
              "raw": "{\n  \"structure_content\": \"## Chapter 1\\nDescription for chapter 1\\n## Chapter 2\\nDescription for chapter 2\",\n  \"usecase_content\": \"Sample usecase content\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/analyze",
              "host": ["{{base_url}}"],
              "path": ["analyze"]
            }
          },
          "response": []
