# Force LF for deploy/runtime files so they work on the Linux server
# regardless of contributors' core.autocrlf settings (CRLF breaks shell
# scripts, Dockerfiles and nginx configs on Linux).
*.sh                text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
*.conf              text eol=lf
Dockerfile          text eol=lf
.dockerignore       text eol=lf
.env.example        text eol=lf
docker-compose.yml  text eol=lf
