# Copy to `.env` (same folder as docker-compose.yml) and fill in.
# On the server this file is written automatically by the GitHub Actions
# deploy workflow from repository Secrets — see DEPLOYMENT.md.

# --- Required secrets (do NOT commit real values) ---
OPENAI_API_KEY=
TAVILY_API_KEY=

# --- Optional ---
OPENAI_MODEL_NAME=gpt-4.1-mini

# --- Host port mapping for the frontend container ---
# The server's main nginx forwards /mrm/ to http://MRM_BIND_ADDR:MRM_HOST_PORT.
# Keep the bind address on 127.0.0.1 so the app is only reachable via that nginx.
MRM_BIND_ADDR=127.0.0.1
MRM_HOST_PORT=8090
